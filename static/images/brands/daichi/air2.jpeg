                    </li>
                                                        <li class="product-card__functions-item is--hidden">
                        <a href="#function-modal" class="product-card__functions-link function-card" data-id="301" data-fancybox="">
                            <img src="/upload/uf/504/30ld0hty8ivjj5rye2kcaxair4r4v5dm/74696c6c562ccc442cc83bb80a821f36.svg" alt="Самодиагностика" class="function-card__icon">
