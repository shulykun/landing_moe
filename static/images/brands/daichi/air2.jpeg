                    </li>
                                                        <li class="product-card__functions-item is--hidden">
                        <a href="#function-modal" class="product-card__functions-link function-card" data-id="242" data-fancybox="">
                            <img src="/upload/uf/50b/gj32n0yxghyate30q2i2gi6p5y8bpazm/5afaf984a5dbcad68baa4c46a0bbc463.svg" alt="Вертикальное распределение" class="function-card__icon">
