                    </li>
                                                        <li class="product-card__functions-item is--hidden">
                        <a href="#function-modal" class="product-card__functions-link function-card" data-id="295" data-fancybox="">
                            <img src="/upload/uf/bff/xlkj44cy3v1kspoj87cb383gdw1r5hgs/86dce1169482007a69c18b85e0337520.svg" alt="Работа по таймеру 24/7" class="function-card__icon">
